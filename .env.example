# Токен бота от @BotFather
BOT_TOKEN=

# Telegram API (получить на https://my.telegram.org)
# нужны для Local Bot API (контейнер bot-api)
API_ID=
API_HASH=

# Внешний порт для bot-api (должен быть уникален среди всех ботов на сервере)
BOT_API_PORT=8098

# Юзернейм бота (без @, используется в справке)
BOT_USERNAME=your_bot_username

# PostgreSQL
DB_HOST=postgres
DB_PORT=5432
DB_NAME=bot_4_pdf
DB_USER=bot_4_pdf
DB_PASSWORD=

# Администраторы бота (через запятую, без пробелов)
ADMIN_IDS=

# Юзернейм главного админа (для отображения в справке)
ADMIN_USERNAME=admin
