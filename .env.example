# ==================== ОБЯЗАТЕЛЬНЫЕ ====================

# Токен бота от @BotFather
BOT_TOKEN=

# Telegram API (получить на https://my.telegram.org)
# нужны для контейнера Local Bot API (лимит файлов до 2 ГБ)
API_ID=
API_HASH=

# Уникальный внешний порт для контейнера bot-api (не должен конфликтовать с другими ботами)
BOT_API_PORT=8098

# Юзернейм бота (без @, показывается в /help)
BOT_USERNAME=your_bot_username

# ==================== БАЗА ДАННЫХ ====================

DB_HOST=postgres
DB_PORT=5432
DB_NAME=bot_4_pdf
DB_USER=bot_4_pdf
DB_PASSWORD=

# ==================== АДМИНЫ ====================

# Telegram ID админов через запятую, без пробелов
ADMIN_IDS=

# Юзернейм главного админа (для отображения в /help)
ADMIN_USERNAME=admin
